<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completed Request"
                android:textAppearance="?attr/textAppearanceHeadline5"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_blue_bg"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Requester: CS21B012"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seminar Hall"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/text_secondary"
                        android:textAppearance="?attr/textAppearanceBody2"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dec 20, 2024 | 10:00 - 11:00"
                        android:textColor="@color/text_secondary"
                        android:textAppearance="?attr/textAppearanceBody2"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1AFFFFFF"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:id="@+id/tvFinalStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Final Decision: Approved"
                        android:textAppearance="?attr/textAppearanceBody1"
                        android:textStyle="bold"
                        android:textColor="@color/status_available"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remarks: Approved for departmental meeting."
                        android:textColor="@color/text_secondary"
                        android:textAppearance="?attr/textAppearanceBody2"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewDocuments"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="View Documents"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="30dp"
                app:strokeColor="@color/white"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelBooking"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Cancel Booking"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="30dp"
                app:strokeColor="@color/status_booked"
                android:textColor="@color/status_booked"
                android:visibility="visible" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>