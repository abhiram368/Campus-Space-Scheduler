<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/colorSurface">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/uploadJsonBtn"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload Schedule JSON"
        android:textColor="?attr/colorPrimary"
        app:backgroundTint="?attr/colorPrimaryContainer" />

    <TextView
        android:id="@+id/currentSpaceHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dp"
        android:text="No Space Selected"
        android:textColor="?attr/colorOnSurface"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp">

        <!-- Available -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="8dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#4CAF50"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Booked -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="8dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#F44336"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Booked"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Pending -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="8dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#FF9800"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Blocked -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="8dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#9E9E9E"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blocked"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:fillViewport="true">

        <TableLayout
            android:id="@+id/weekPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorOutline"
            android:stretchColumns="*" />
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/viewScheduleBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Schedule"
        android:textStyle="bold"
        android:textColor="?attr/colorOnPrimary"
        app:backgroundTint="?attr/colorPrimary" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/editScheduleBtn"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit Schedule"
        android:textColor="?attr/colorPrimary"
        app:backgroundTint="?attr/colorPrimaryContainer" />

    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"/>

</LinearLayout>