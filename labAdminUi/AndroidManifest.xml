<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.labadmin">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Lab Admin"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LabAdmin">

        <activity
            android:name=".LabAdminDashboardActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ReassignActivity" android:exported="false" />
        <activity android:name=".ReportIssueActivity" android:exported="false" />
        <activity android:name=".AssignedSessionDetailsActivity" android:exported="false" />
        <activity android:name=".UploadPhotoActivity" android:exported="false" />

    </application>

</manifest>