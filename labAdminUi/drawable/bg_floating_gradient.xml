<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Gradient Background -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:endColor="@color/bg_gradient_end"
                android:startColor="@color/bg_gradient_start"
                android:type="linear" />
        </shape>
    </item>

    <!-- Top Left Floating Glow -->
    <item android:top="-100dp" android:left="-100dp" android:right="150dp" android:bottom="400dp">
        <shape android:shape="oval">
            <gradient
                android:centerX="0.5"
                android:centerY="0.5"
                android:gradientRadius="250dp"
                android:startColor="@color/glow_blue"
                android:endColor="#00000000"
                android:type="radial" />
        </shape>
    </item>

    <!-- Bottom Right Floating Glow -->
    <item android:top="400dp" android:left="150dp" android:right="-100dp" android:bottom="-100dp">
        <shape android:shape="oval">
            <gradient
                android:centerX="0.5"
                android:centerY="0.5"
                android:gradientRadius="300dp"
                android:startColor="@color/glow_purple"
                android:endColor="#00000000"
                android:type="radial" />
        </shape>
    </item>
</layer-list>