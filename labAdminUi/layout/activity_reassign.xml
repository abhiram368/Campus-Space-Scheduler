<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reassign Lab Admin"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/edtReason"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:hint="Enter reason for reassignment"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:background="@drawable/bg_secondary_action"
        android:padding="16dp"
        android:gravity="top"
        android:inputType="textMultiLine"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnConfirmReassign"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Confirm Reassignment"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_primary_action"
        app:backgroundTint="@null"/>

</LinearLayout>
