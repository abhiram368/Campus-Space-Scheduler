<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/uploadJsonBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload Schedule JSON" />

    <TextView
        android:id="@+id/currentSpaceHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="8dp"
        android:text="No Space Selected"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:fillViewport="true">

        <TableLayout
            android:id="@+id/weekPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#A9A9A9"
            android:stretchColumns="*" />
    </ScrollView>

    <Button
        android:id="@+id/viewScheduleBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Schedule" />

    <Button
        android:id="@+id/editScheduleBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit Schedule" />

    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"/>

</LinearLayout>