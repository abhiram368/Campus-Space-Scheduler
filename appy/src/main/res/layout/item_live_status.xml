<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/ProfessionalCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSpaceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Space Name"
                style="@style/TitleMedium" />

            <TextView
                android:id="@+id/tvSlotInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Slot: --"
                style="@style/BodySecondary"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvLastUpdated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last updated: 10 mins ago"
                style="@style/BodySecondary"
                android:textSize="10sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/ivStatusDot"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/badge_green" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AVAILABLE"
                style="@style/BadgeText"
                android:textColor="@color/status_available"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
