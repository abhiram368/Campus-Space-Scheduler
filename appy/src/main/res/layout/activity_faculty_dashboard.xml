<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Integrated Header Section -->
            <include
                android:id="@+id/headerLayout"
                layout="@layout/layout_common_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Navigation Grid -->
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Pending Requests -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnEscalated"
                            android:layout_width="0dp"
                            android:layout_height="150dp"
                            android:layout_weight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:strokeWidth="0dp"
                            app:cardElevation="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="@drawable/glass_blue_bg"
                                android:padding="20dp"
                                android:gravity="start|center_vertical">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@android:drawable/ic_dialog_alert"
                                    app:tint="@color/accent_blue"
                                    android:layout_marginBottom="16dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Pending"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Requests"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Live Status -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnLiveStatus"
                            android:layout_width="0dp"
                            android:layout_height="150dp"
                            android:layout_weight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:strokeWidth="0dp"
                            app:cardElevation="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="@drawable/glass_blue_bg"
                                android:padding="20dp"
                                android:gravity="start|center_vertical">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@android:drawable/presence_online"
                                    app:tint="@color/accent_teal"
                                    android:layout_marginBottom="16dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Live"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Status"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- View Schedule -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnViewSchedule"
                            android:layout_width="0dp"
                            android:layout_height="150dp"
                            android:layout_weight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:strokeWidth="0dp"
                            app:cardElevation="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="@drawable/glass_blue_bg"
                                android:padding="20dp"
                                android:gravity="start|center_vertical">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@android:drawable/ic_menu_today"
                                    app:tint="@color/accent_blue"
                                    android:layout_marginBottom="16dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="View"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Schedule"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Approval History -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnApprovalHistory"
                            android:layout_width="0dp"
                            android:layout_height="150dp"
                            android:layout_weight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:strokeWidth="0dp"
                            app:cardElevation="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="@drawable/glass_blue_bg"
                                android:padding="20dp"
                                android:gravity="start|center_vertical">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@android:drawable/ic_menu_recent_history"
                                    app:tint="@color/accent_teal"
                                    android:layout_marginBottom="16dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Approval"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="History"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Lab Details -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnLabDetails"
                            android:layout_width="0dp"
                            android:layout_height="150dp"
                            android:layout_weight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:strokeWidth="0dp"
                            app:cardElevation="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="@drawable/glass_blue_bg"
                                android:padding="20dp"
                                android:gravity="start|center_vertical">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@android:drawable/ic_menu_info_details"
                                    app:tint="@color/accent_blue"
                                    android:layout_marginBottom="16dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Lab"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Details"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Lab Admins -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnLabAdmins"
                            android:layout_width="0dp"
                            android:layout_height="150dp"
                            android:layout_weight="1"
                            android:layout_margin="8dp"
                            app:cardCornerRadius="28dp"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:strokeWidth="0dp"
                            app:cardElevation="8dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:background="@drawable/glass_blue_bg"
                                android:padding="20dp"
                                android:gravity="start|center_vertical">

                                <ImageView
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:src="@android:drawable/ic_menu_myplaces"
                                    app:tint="@color/accent_teal"
                                    android:layout_marginBottom="16dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Lab"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Admins"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                </androidx.appcompat.widget.LinearLayoutCompat>

                <!-- BOOK BUTTON -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBookResource"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="24dp"
                    android:text="Book Resource"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:background="@drawable/gold_gradient_bg"
                    app:backgroundTint="@null"
                    app:cornerRadius="32dp"
                    app:elevation="8dp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>