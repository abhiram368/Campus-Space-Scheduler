<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/completed_request_details_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- BASIC DETAILS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/student_jane_doe"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lab_computer_networks"
            android:layout_marginTop="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/timeslot_10_12"
            android:layout_marginTop="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/usage_status_completed"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginTop="10dp"/>

        <!-- STUDENT STATUS -->
        <TextView
            android:id="@+id/tvBlockStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/student_status_active"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginTop="20dp"/>

        <!-- REMARK -->
        <EditText
            android:id="@+id/remarkBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/enter_remark_hint"
            android:inputType="text"
            android:autofillHints=""
            android:layout_marginTop="12dp"/>

        <!-- ACTION BUTTONS -->
        <Button
            android:id="@+id/btnBlockStudent"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/block_student"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:background="@drawable/rounded_red_button"/>

        <Button
            android:id="@+id/btnUnblockStudent"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/unblock_student"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:background="@drawable/rounded_green_button"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>