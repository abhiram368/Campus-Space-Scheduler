<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_gradient_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Request Detail"
                android:textAppearance="?attr/textAppearanceHeadline5"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp"
                app:cardElevation="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/glass_blue_bg"
                    android:padding="24dp">
                    <TextView
                        android:id="@+id/usernameTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Requester: CS21B034"
                        android:textAppearance="?attr/textAppearanceHeadline6"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Computer Networks Lab"
                        android:textAppearance="?attr/textAppearanceBody1"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                    <TextView
                        android:id="@+id/timeSlotTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dec 24, 2024 | 14:00 - 16:00"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="@color/text_secondary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1A000000"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reason"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="@color/text_secondary"
                        android:textAllCaps="true"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Academic project requirement for networking experiments."
                        android:textAppearance="?attr/textAppearanceBody1"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewLor"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="View Documents"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:cornerRadius="30dp"
                app:strokeColor="@color/white"
                android:textColor="@color/white"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Remarks (optional)"
                android:textColorHint="@color/white"
                app:hintTextColor="@color/white"
                app:boxStrokeColor="@color/white"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/remarkBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:lines="3"
                    android:gravity="top"/>
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApprove"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="60dp"
                    android:text="Approve"
                    app:cornerRadius="30dp"
                    android:backgroundTint="@color/status_available"
                    android:textColor="@android:color/white"
                    android:layout_marginEnd="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReject"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="60dp"
                    android:text="Reject"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:cornerRadius="30dp"
                    app:strokeColor="@color/status_booked"
                    android:textColor="@color/status_booked"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForward"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Forward to HOD"
                android:layout_marginTop="16dp"
                app:cornerRadius="30dp"
                android:backgroundTint="@color/accent_blue"
                android:textColor="@android:color/white"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>